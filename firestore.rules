rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isConfirmedStatus() {
      return request.resource.data.status == 'confirmed';
    }

    function hasTrialSiteName() {
      return request.resource.data.customerName is string
        && request.resource.data.customerName.size() >= 10
        && request.resource.data.customerName.size() <= 120
        && request.resource.data.customerName.matches('.*אוטומטי שיעור נסיון.*');
    }

    function isValidDateKey(value) {
      return value is string
        && value.size() == 10
        && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isValidManualCreate() {
      return isConfirmedStatus()
        && hasTrialSiteName()
        && request.resource.data.eventId is string
        && request.resource.data.eventId.size() > 0
        && request.resource.data.eventId.size() < 128
        && isValidDateKey(request.resource.data.dateKey)
        && request.resource.data.keys().hasAll([
          'customerName',
          'eventId',
          'occurrenceDate',
          'date',
          'dateKey',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.occurrenceDate is timestamp
        && request.resource.data.date is timestamp
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (
          !('source' in request.resource.data)
          || request.resource.data.source == 'trial_site'
        );
    }

    function isValidOccurrenceCountShape(countId) {
      return request.resource.data.keys().hasAll(['eventId', 'dateKey', 'count', 'updatedAt'])
        && request.resource.data.eventId is string
        && request.resource.data.eventId.size() > 0
        && request.resource.data.eventId.size() < 128
        && isValidDateKey(request.resource.data.dateKey)
        && request.resource.data.count is int
        && request.resource.data.count >= 0
        && request.resource.data.count <= 50
        && request.resource.data.updatedAt is timestamp
        && countId == request.resource.data.eventId + '_' + request.resource.data.dateKey;
    }

    // Trial site may seed/heal a missing counter to the real confirmed total,
    // or create the first count (=1) for an empty occurrence.
    function isValidOccurrenceCountCreate(countId) {
      return isValidOccurrenceCountShape(countId);
    }

    // After a trial reservation: allow raising the counter (+1 or heal jump), never lowering it.
    function isValidOccurrenceCountIncrement(countId) {
      return isValidOccurrenceCountShape(countId)
        && request.resource.data.eventId == resource.data.eventId
        && request.resource.data.dateKey == resource.data.dateKey
        && request.resource.data.count > resource.data.count;
    }

    match /events/{eventId} {
      allow read: if resource.data.isActive == true;
      allow write: if false;
    }

    match /event_registrations/{registrationId} {
      allow read: if resource.data.status == 'confirmed';
      allow write: if false;
    }

    match /event_manual_registrations/{registrationId} {
      allow read: if resource.data.status == 'confirmed';
      allow create: if isValidManualCreate();
      allow update, delete: if false;
    }

    match /event_cancellations/{cancellationId} {
      allow read: if true;
      allow write: if false;
    }

    // Per-occurrence registration counter used by ArtHub capacity checks.
    // Trial site must read + bump this when creating a manual trial reservation.
    match /occurrence_counts/{countId} {
      allow read: if true;
      allow create: if isValidOccurrenceCountCreate(countId);
      allow update: if isValidOccurrenceCountIncrement(countId);
      allow delete: if false;
    }

    // Deny everything else from clients (Admin SDK bypasses rules)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
